---
import Base from '../layouts/Base.astro';
import SocialIcon from '../components/SocialIcon.astro';

const socials = [
  {
    name: 'simple-icons:github',
    url: 'https://github.com/klitztuch',
    label: 'GitHub',
  },
  {
    name: 'simple-icons:keybase',
    url: 'https://keybase.io/klitztuch',
    label: 'Keybase',
  },
  {
    name: 'simple-icons:linkedin',
    url: 'https://www.linkedin.com/in/markus-rothl%C3%BCbbers-58420b18b/',
    label: 'LinkedIn',
  },
  {
    name: 'simple-icons:strava',
    url: 'https://www.strava.com/athletes/klitztuch',
    label: 'Strava',
  },
];
---

<Base>
  <main class="flex flex-1 items-center justify-center px-4">
    <div class="text-center">
      <h1 class="text-4xl font-bold tracking-tight">Moin 👋</h1>
      <div class="mt-6 flex items-center justify-center gap-4">
        {socials.map((s) => <SocialIcon name={s.name} url={s.url} label={s.label} />)}
      </div>
    </div>
  </main>
</Base>
