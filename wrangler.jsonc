{
	"compatibility_date": "2026-04-11",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "r9s-dev",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"build": {
		"command": "npm run build"
	},
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}