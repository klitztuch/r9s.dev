{
	"compatibility_date": "2026-04-11",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "r9s-dev",
	"main": "./dist/server/entry.mjs",
	"build": {
		"command": "npx astro build"
	},
	"assets": {
		"directory": "./dist/client",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}